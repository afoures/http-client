    "@types/node": "^24.10.13",
    "msw": "^2.12.10",
    "oxfmt": "^0.25.0",
    "oxlint": "^1.48.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@remix-run/route-pattern": "^0.18.0",
    "@standard-schema/spec": "^1.1.0"
